{
  "name": "gamesound-fx",
  "private": true,
  "version": "1.0.0",
  "description": "Game Sound FX - 游戏音效助手",
  "author": "GameSound FX Team",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npx vite",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npx vite build",
    "build:electron": "npx tsc -p tsconfig.electron.json",
    "start": "npm run clean && npm run build && npm run build:electron && npx electron .",
    "generate-icons": "node scripts/generate-icons.js && node scripts/generate-icons-png.js",
    "lint": "eslint .",
    "preview": "npx vite preview",
    "electron:dev": "VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:build": "npm run generate-icons && npm run build && npm run build:electron && npx electron-builder --win"
  },
  "build": {
    "appId": "com.gamesoundfx.app",
    "productName": "GameSound FX",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "!dist/sounds/**/*",
      "assets/**/*",
      "dist/main.js"
    ],
    "compression": "maximum",
    "extraResources": [
      {
        "from": "public/sounds",
        "to": "sounds"
      },
      {
        "from": "scripts/poll_helper.ps1",
        "to": "poll_helper.ps1"
      },
      {
        "from": "scripts/gsfx_poller.exe",
        "to": "gsfx_poller.exe"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": false,
      "publish": [
        "github"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GameSound FX"
    }
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "howler": "^2.2.4",
    "koffi": "^2.16.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.12.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "ffmpeg-static": "^5.3.0",
    "globals": "^16.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
